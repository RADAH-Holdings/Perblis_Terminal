{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "python manage.py deploy --noinput",
    "startCommand": "python manage.py db_worker",
    "restartPolicyType": "ON_FAILURE"
  }
}
